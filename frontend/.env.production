# Frontend environment variables - production (Vercel)
# ⚠️  DO NOT add secrets, API keys, or tokens here — this file is committed to git.
#    Set sensitive values (e.g. REACT_APP_VAPID_PUBLIC_KEY) in the Vercel dashboard
#    under Project Settings → Environment Variables instead.

# Backend API URL for production
REACT_APP_BACKEND_URL=https://api.shramsetu.in


DISABLE_ESLINT_PLUGIN=true
ESLINT_NO_DEV_ERRORS=true
