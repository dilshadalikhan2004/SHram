# Frontend environment variables - local development
# ⚠️  DO NOT add secrets, API keys, or tokens here — this file is committed to git.
#    For sensitive local overrides, use .env.local (which is gitignored).

# Backend API URL for local development
REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_BACKEND_URL=https://api.shramsetu.in

# VAPID public key for push notifications (generate with: npx web-push generate-vapid-keys)
# Set this in .env.local to avoid committing your key
# REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key_here
