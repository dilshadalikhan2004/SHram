# Backend environment variables template
# Copy this file to .env and fill in the actual values

# CORS: comma-separated list of allowed frontend origins
# If not set, defaults to localhost and production domains in server.py
CORS_ORIGINS=https://www.shramsetu.in,https://shramsetu.in,https://s-hram.vercel.app,http://localhost:3000

# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=shramsetu

# JWT authentication
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Server
PORT=8000

# Frontend URL (used by subscription_routes for redirect URLs)
FRONTEND_URL=https://www.shramsetu.in

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio (OTP / SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Cloudinary (media uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Web Push (VAPID keys – generate with: npx web-push generate-vapid-keys)
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key

# Payment rates
PLATFORM_FEE_PCT=7.5
TDS_RATE_WITH_PAN=1.0
TDS_RATE_WITHOUT_PAN=20.0
